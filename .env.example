# === LeShell Configuration ===

# HuggingFace token for NL2Shell model inference (optional, avoids rate limits)
# HF_TOKEN=hf_...

# Supabase for feedback persistence (optional)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# IP_SALT=random-salt-for-privacy

# Sandbox relay server URL (required for execution feature)
SANDBOX_RELAY_URL=http://localhost:4000

# Enable sandbox execution UI
NEXT_PUBLIC_SANDBOX_ENABLED=true

# Enable MCP endpoint
NEXT_PUBLIC_MCP_ENABLED=true

# Sandbox relay URL (client-side, for direct relay access if needed)
# NEXT_PUBLIC_SANDBOX_RELAY_URL=http://localhost:4000
